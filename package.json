  },
  "homepage": "https://github.com/Streampay-Org/StreamPay-Backend#readme",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",

  "description": "StreamPay API — stream management, metering, and settlement",
  "keywords": [
    "streampay",
    "stellar",
    "payments",
    "streaming",
    "metering",
    "settlement",
    "drizzle",
    "express",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Streampay-Org/StreamPay-Backend.git"
  },
  "bugs": {

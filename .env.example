# StreamPay Backend Environment Variables
#
# Copy this file to `.env` and fill in real values for local development.
# Never commit real secrets to source control.

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Database ---
DATABASE_URL=postgres://user:password@localhost:5432/streampay
# Optional pool tuning (defaults shown).
# DB_POOL_MAX=10
# DB_POOL_IDLE_TIMEOUT=30000
# DB_CONNECTION_TIMEOUT=5000
# DB_STATEMENT_TIMEOUT=30000

# --- Auth ---
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars_long
# Optional RS256 verification key (PEM, \n escaped).
# JWT_PUBLIC_KEY=
# JWT_ISSUER=
# JWT_AUDIENCE=
# API_KEYS=
# API_KEY_HASHES=

# --- RPC / Chain ---
RPC_URL=https://api.mainnet-beta.solana.com
# Optional deep health probe controls.
# HEALTH_CHECK_TIMEOUT_MS=5000
# RPC_PROBE_ENABLED=false

# --- Webhooks ---
# INDEXER_WEBHOOK_SECRET=

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Rate limiting (defaults shown) ---
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=100
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=20

# StreamPay Backend Environment Variables

PORT=3001
DATABASE_URL=postgres://user:password@localhost:5432/streampay
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars_long
RPC_URL=https://api.mainnet-beta.solana.com
NODE_ENV=development

# Rate limiting (optional — defaults shown)
# Global limiter: 100 requests per 60 seconds per IP / API key
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
# Auth limiter: 20 requests per 15 minutes per IP / API key
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=20
